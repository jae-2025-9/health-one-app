# Copy to .env and adjust. Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://health:health@localhost:5432/health_one?schema=public"
PORT=3000
CORS_ORIGIN="http://localhost:3000"

# Dev-only stubbed identity. L1 will replace this with real JWT auth.
# The server falls back to this user id when no X-User-Id header is sent.
DEV_USER_ID="00000000-0000-0000-0000-000000000001"

# Optional server-side AI provider settings. Keep real API keys out of git.
UPSTAGE_BASE_URL="https://api.upstage.ai/v1"
UPSTAGE_MODEL="solar-pro3"
UPSTAGE_API_KEY=""
